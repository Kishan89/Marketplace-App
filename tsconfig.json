{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "types": ["jest"],
    "baseUrl": ".",
    "paths": {
      "@features/*": ["src/features/*"],
      "@shared/*": ["src/shared/*"],
      "@core/*": ["src/core/*"],
      "@store/*": ["src/store/*"],
      "@assets/*": ["assets/*"]
    }
  },
  "include": ["src", "__tests__", "App.tsx", "index.ts"]
}
